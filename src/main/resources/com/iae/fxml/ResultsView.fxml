<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.iae.ui.ResultsViewController"
      styleClass="results-pane"
      stylesheets="@../css/styles.css">

    <!-- ── Summary bar ─────────────────────────────────────────────── -->
    <HBox styleClass="summary-bar">

        <VBox styleClass="summary-card" alignment="CENTER" spacing="2">
            <Label fx:id="totalLabel" text="0" styleClass="summary-count"/>
            <Label text="Total" styleClass="summary-label"/>
        </VBox>

        <!-- check_circle = E86C -->
        <VBox styleClass="summary-card summary-pass" alignment="CENTER" spacing="2">
            <HBox alignment="CENTER" spacing="4">
                <Label text="&#xE86C;" style="-fx-font-family:'Material Icons';-fx-font-size:14px;-fx-text-fill:#1a7a34;"/>
                <Label fx:id="passLabel" text="0" styleClass="summary-count" style="-fx-text-fill:#1a7a34;"/>
            </HBox>
            <Label text="Pass" styleClass="summary-label"/>
        </VBox>

        <!-- cancel = E5C9 -->
        <VBox styleClass="summary-card summary-fail" alignment="CENTER" spacing="2">
            <HBox alignment="CENTER" spacing="4">
                <Label text="&#xE5C9;" style="-fx-font-family:'Material Icons';-fx-font-size:14px;-fx-text-fill:#ba1a1a;"/>
                <Label fx:id="failLabel" text="0" styleClass="summary-count" style="-fx-text-fill:#ba1a1a;"/>
            </HBox>
            <Label text="Fail" styleClass="summary-label"/>
        </VBox>

        <!-- warning = E002 -->
        <VBox styleClass="summary-card summary-error" alignment="CENTER" spacing="2">
            <HBox alignment="CENTER" spacing="4">
                <Label text="&#xE002;" style="-fx-font-family:'Material Icons';-fx-font-size:14px;-fx-text-fill:#c07a00;"/>
                <Label fx:id="errorLabel" text="0" styleClass="summary-count" style="-fx-text-fill:#c07a00;"/>
            </HBox>
            <Label text="Error" styleClass="summary-label"/>
        </VBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <!-- replay = E042  file_download = E2C4 -->
        <Button styleClass="secondary-button" onAction="#handleReRun">
            <graphic><Label text="&#xE042;"
                            style="-fx-font-family:'Material Icons';-fx-font-size:14px;-fx-text-fill:#424752;"/></graphic>
            Re-Run
        </Button>
        <Button styleClass="secondary-button" onAction="#handleExport">
            <graphic><Label text="&#xE2C4;"
                            style="-fx-font-family:'Material Icons';-fx-font-size:14px;-fx-text-fill:#424752;"/></graphic>
            Export CSV
        </Button>

    </HBox>

    <!-- ── Results table + detail panel ───────────────────────────── -->
    <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS" dividerPositions="0.62">

        <TableView fx:id="resultsTable" styleClass="data-table results-table">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="No results yet." style="-fx-text-fill:#727783;-fx-font-size:12px;"/>
            </placeholder>
        </TableView>

        <!-- Detail output panel -->
        <VBox styleClass="detail-panel">
            <HBox styleClass="detail-panel-header">
                <Label text="Detail Output" styleClass="detail-panel-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Label fx:id="detailStudentLabel" text="" styleClass="detail-student-label"/>
                <!-- close = E5CD -->
                <Button styleClass="ghost-button" onAction="#handleClearDetail"
                        contentDisplay="GRAPHIC_ONLY">
                    <graphic><Label text="&#xE5CD;"
                                   style="-fx-font-family:'Material Icons';-fx-font-size:16px;-fx-text-fill:#727783;"/></graphic>
                </Button>
            </HBox>
            <TextArea fx:id="detailOutputArea" editable="false" styleClass="log-area"
                      VBox.vgrow="ALWAYS"
                      promptText="Select a student row to see detailed output…"/>
        </VBox>

    </SplitPane>

</VBox>
