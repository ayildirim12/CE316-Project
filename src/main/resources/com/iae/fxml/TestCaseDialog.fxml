<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.iae.ui.TestCaseDialogController"
      styleClass="progress-dialog-root"
      spacing="14" prefWidth="460" minWidth="380"
      stylesheets="@../css/styles.css">

    <padding><Insets top="24" right="24" bottom="20" left="24"/></padding>

    <!-- Title  assignment = E85D -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="&#xE85D;" styleClass="progress-dialog-icon"/>
        <Label fx:id="dialogTitle" text="Add Test Case" styleClass="progress-dialog-title"/>
    </HBox>

    <Pane styleClass="section-divider" maxHeight="1"/>

    <!-- Input Arguments -->
    <VBox spacing="4">
        <Label text="INPUT ARGUMENTS" styleClass="field-label"/>
        <TextField fx:id="inputArgsField" styleClass="text-field"
                   promptText="e.g. --input 5  (leave blank if none)"/>
    </VBox>

    <!-- Expected Output File -->
    <VBox spacing="4">
        <Label text="EXPECTED OUTPUT FILE" styleClass="field-label"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <!-- attach_file = E226 -->
            <Button styleClass="toolbar-icon-btn" onAction="#handleBrowseOutputFile"
                    contentDisplay="GRAPHIC_ONLY">
                <graphic><Label text="&#xE226;" styleClass="toolbar-icon"/></graphic>
                <tooltip><Tooltip text="Browse…"/></tooltip>
            </Button>
            <TextField fx:id="expectedOutputFileField" styleClass="text-field"
                       promptText="Path to expected output .txt file"
                       editable="false" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="8">
        <padding><Insets top="6"/></padding>
        <Button text="Cancel" styleClass="secondary-button" onAction="#handleCancel"/>
        <Button text="Add" styleClass="primary-button" onAction="#handleAdd"/>
    </HBox>

</VBox>
