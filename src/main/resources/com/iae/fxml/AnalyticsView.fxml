<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.iae.ui.AnalyticsViewController"
      spacing="16"
      styleClass="analytics-view">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Analytics" styleClass="view-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton" text="↻  Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
    </HBox>

    <!-- Summary Cards -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="TOTAL PROJECTS" styleClass="stat-label"/>
            <Label fx:id="totalProjectsLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
            <Label text="TOTAL SUBMISSIONS" styleClass="stat-label"/>
            <Label fx:id="totalSubmissionsLabel" text="0" styleClass="stat-value"/>
        </VBox>
        <VBox styleClass="stat-card stat-card-pass" HBox.hgrow="ALWAYS">
            <Label text="OVERALL PASS RATE" styleClass="stat-label"/>
            <Label fx:id="overallPassRateLabel" text="0%" styleClass="stat-value stat-value-pass"/>
        </VBox>
    </HBox>

    <!-- Per-Project Table -->
    <Label text="Per-Project Breakdown" styleClass="section-title"/>

    <TableView fx:id="analyticsTable" VBox.vgrow="ALWAYS" styleClass="analytics-table">
        <columns>
            <TableColumn fx:id="colProject"     text="Project"            prefWidth="200"/>
            <TableColumn fx:id="colTotal"       text="Total Submissions"  prefWidth="150"/>
            <TableColumn fx:id="colPass"        text="Pass"               prefWidth="80"/>
            <TableColumn fx:id="colFail"        text="Fail"               prefWidth="80"/>
            <TableColumn fx:id="colError"       text="Error"              prefWidth="80"/>
            <TableColumn fx:id="colPassRate"    text="Pass Rate %"        prefWidth="120"/>
            <TableColumn fx:id="colLastRun"     text="Last Run"           prefWidth="160"/>
        </columns>
        <placeholder>
            <Label text="No projects found. Run an evaluation first." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

</VBox>
