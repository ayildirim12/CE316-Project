<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.iae.ui.ProjectDialogController"
      styleClass="progress-dialog-root"
      spacing="14" prefWidth="460" minWidth="380">

    <padding><Insets top="24" right="24" bottom="20" left="24"/></padding>

    <!-- Title  account_tree = E97A -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="&#xE97A;" styleClass="progress-dialog-icon"/>
        <Label fx:id="dialogTitle" text="New Project" styleClass="progress-dialog-title"/>
    </HBox>

    <Pane styleClass="section-divider" maxHeight="1"/>

    <!-- Project Name -->
    <VBox spacing="4">
        <Label text="PROJECT NAME" styleClass="field-label"/>
        <TextField fx:id="nameField" styleClass="text-field"
                   promptText="e.g. CS101 Homework 1"/>
    </VBox>

    <!-- Configuration dropdown -->
    <VBox spacing="4">
        <Label text="CONFIGURATION" styleClass="field-label"/>
        <ComboBox fx:id="configComboBox" styleClass="text-field"
                  promptText="Select a configuration…" maxWidth="Infinity"/>
    </VBox>

    <!-- Submissions Directory -->
    <VBox spacing="4">
        <Label text="SUBMISSIONS DIRECTORY" styleClass="field-label"/>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <!-- folder = E2C7 -->
            <Button styleClass="toolbar-icon-btn" onAction="#handleBrowse"
                    contentDisplay="GRAPHIC_ONLY">
                <graphic><Label text="&#xE2C7;" styleClass="toolbar-icon"/></graphic>
                <tooltip><Tooltip text="Browse…"/></tooltip>
            </Button>
            <TextField fx:id="submissionsDirField" styleClass="text-field"
                       promptText="Select a directory containing student ZIP files"
                       editable="false" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- Buttons -->
    <HBox alignment="CENTER_RIGHT" spacing="8">
        <padding><Insets top="6"/></padding>
        <Button text="Cancel" styleClass="secondary-button" onAction="#handleCancel"/>
        <Button fx:id="createBtn" text="Create" styleClass="primary-button" onAction="#handleCreate"/>
    </HBox>

</VBox>
